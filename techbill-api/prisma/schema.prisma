generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                    String               @id @default(uuid()) @db.Uuid
  name                  String               @db.VarChar(255)
  slug                  String               @unique @db.VarChar(100)
  status                String               @default("active") @db.VarChar(50)
  plan                  String               @default("trial") @db.VarChar(50)
  trialEndsAt           DateTime?            @map("trial_ends_at")
  currentPeriodEnd      DateTime?            @map("current_period_end")
  maxUsers              Int                  @default(5) @map("max_users")
  createdAt             DateTime             @default(now()) @map("created_at")
  updatedAt             DateTime             @updatedAt @map("updated_at")
  onlineSellingEnabled  Boolean              @default(false) @map("online_selling_enabled")
  appAccessEnabled      Boolean              @default(false) @map("app_access_enabled")
  isWarehouseEnabled    Boolean              @default(false) @map("is_warehouse_enabled")
  subscriptionExpiresAt DateTime?            @map("subscription_expires_at")
  auditLogs             AuditLog[]
  cashDrawerSessions    CashDrawerSession[]
  reconciliations       CashReconciliation[]
  courierPayouts        CourierPayout[]
  customers             Customer[]
  expenses              Expense[]
  goodsReceived         GoodsReceivedNote[]
  inventoryUnits        InventoryUnit[]
  notifications         Notification[]
  products              Product[]
  purchaseOrders        PurchaseOrder[]
  returns               Return[]
  sales                 Sale[]
  settings              ShopSettings[]
  suppliers             Supplier[]
  transactions          Transaction[]
  users                 User[]

  @@map("tenants")
}

model User {
  id                       String               @id @default(uuid()) @db.Uuid
  name                     String               @db.VarChar(100)
  email                    String               @unique @db.VarChar(255)
  passwordHash             String               @map("password_hash") @db.VarChar(255)
  role                     Role
  isActive                 Boolean              @default(true) @map("is_active")
  tenantId                 String?              @map("tenant_id") @db.Uuid
  permissions              String[]             @default([])
  createdAt                DateTime             @default(now()) @map("created_at")
  updatedAt                DateTime             @updatedAt @map("updated_at")
  auditLogs                AuditLog[]
  cashDrawerSessions       CashDrawerSession[]
  reconciliationsReviewed  CashReconciliation[] @relation("ReconciliationsReviewedBy")
  reconciliationsSubmitted CashReconciliation[] @relation("ReconciliationsSubmittedBy")
  courierPayouts           CourierPayout[]      @relation("PayoutsCreatedBy")
  expenses                 Expense[]            @relation("ExpensesCreatedBy")
  goodsReceived            GoodsReceivedNote[]
  notifications            Notification[]
  products                 Product[]
  purchaseOrders           PurchaseOrder[]
  refreshTokens            RefreshToken[]
  returnsRequested         Return[]             @relation("ReturnsRequestedBy")
  returnsReviewed          Return[]             @relation("ReturnsReviewedBy")
  salesDiscountApproved    Sale[]               @relation("SalesDiscountApproved")
  salesAsCashier           Sale[]               @relation("SalesSoldBy")
  salesVoided              Sale[]               @relation("SalesVoided")
  tenant                   Tenant?              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  token     String    @unique
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model ShopSettings {
  id                        String   @id @default(uuid()) @db.Uuid
  shopName                  String   @map("shop_name") @db.VarChar(255)
  lowStockThreshold         Int      @default(2) @map("low_stock_threshold")
  deadStockDays             Int      @default(60) @map("dead_stock_days")
  maxDiscountWithoutOtp     Decimal  @default(500) @map("max_discount_without_otp") @db.Decimal(10, 2)
  returnFraudWindowDays     Int      @default(30) @map("return_fraud_window_days")
  returnFraudCountThreshold Int      @default(2) @map("return_fraud_count_threshold")
  logoUrl                   String?  @map("logo_url")
  invoiceFontFamily         String   @default("Inter") @map("invoice_font_family") @db.VarChar(100)
  invoicePrimaryColor       String   @default("#ffffff") @map("invoice_primary_color") @db.VarChar(7)
  invoiceAccentColor        String   @default("#14b8a6") @map("invoice_accent_color") @db.VarChar(7)
  invoiceFooterNotes        String?  @map("invoice_footer_notes")
  invoiceWatermarkText      String?  @map("invoice_watermark_text") @db.VarChar(255)
  invoiceShowWatermark      Boolean  @default(false) @map("invoice_show_watermark")
  tenantId                  String   @map("tenant_id") @db.Uuid
  updatedAt                 DateTime @updatedAt @map("updated_at")
  tenant                    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("shop_settings")
}

model Product {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String              @db.VarChar(255)
  brand              String?             @db.VarChar(100)
  category           String?             @db.VarChar(100)
  description        String?
  costPrice          Decimal?            @map("cost_price") @db.Decimal(10, 2)
  sellingPrice       Decimal             @map("selling_price") @db.Decimal(10, 2)
  warrantyMonths     Int                 @default(0) @map("warranty_months")
  isActive           Boolean             @default(true) @map("is_active")
  createdById        String?             @map("created_by_id") @db.Uuid
  tenantId           String              @map("tenant_id") @db.Uuid
  createdAt          DateTime            @default(now()) @map("created_at")
  aiSummary          String?             @map("ai_summary")
  comparePrice       Decimal?            @map("compare_price") @db.Decimal(10, 2)
  imageUrl           String?             @map("image_url")
  shortDescription   String?             @map("short_description") @db.VarChar(500)
  specifications     Json?               @db.Json
  tags               String[]            @default([])
  sku                String?             @db.VarChar(100)
  inventoryUnits     InventoryUnit[]
  createdBy          User?               @relation(fields: [createdById], references: [id])
  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrderItems PurchaseOrderItem[]

  @@index([tenantId])
  @@map("products")
}

model Supplier {
  id             String          @id @default(uuid()) @db.Uuid
  name           String          @db.VarChar(255)
  contactName    String?         @map("contact_name") @db.VarChar(100)
  phone          String?         @db.VarChar(20)
  email          String?         @db.VarChar(255)
  address        String?
  tenantId       String          @map("tenant_id") @db.Uuid
  createdAt      DateTime        @default(now()) @map("created_at")
  purchaseOrders PurchaseOrder[]
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("suppliers")
}

model PurchaseOrder {
  id          String              @id @default(uuid()) @db.Uuid
  supplierId  String?             @map("supplier_id") @db.Uuid
  status      POStatus            @default(draft)
  totalAmount Decimal?            @map("total_amount") @db.Decimal(12, 2)
  notes       String?
  createdById String?             @map("created_by_id") @db.Uuid
  tenantId    String              @map("tenant_id") @db.Uuid
  createdAt   DateTime            @default(now()) @map("created_at")
  receivedAt  DateTime?           @map("received_at")
  grns        GoodsReceivedNote[]
  items       PurchaseOrderItem[]
  createdBy   User?               @relation(fields: [createdById], references: [id])
  supplier    Supplier?           @relation(fields: [supplierId], references: [id])
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid()) @db.Uuid
  purchaseOrderId String        @map("purchase_order_id") @db.Uuid
  productId       String        @map("product_id") @db.Uuid
  quantityOrdered Int           @map("quantity_ordered")
  unitCostPrice   Decimal       @map("unit_cost_price") @db.Decimal(10, 2)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@map("purchase_order_items")
}

model GoodsReceivedNote {
  id              String          @id @default(uuid()) @db.Uuid
  purchaseOrderId String?         @map("purchase_order_id") @db.Uuid
  receivedById    String?         @map("received_by_id") @db.Uuid
  notes           String?
  tenantId        String          @map("tenant_id") @db.Uuid
  receivedAt      DateTime        @default(now()) @map("received_at")
  purchaseOrder   PurchaseOrder?  @relation(fields: [purchaseOrderId], references: [id])
  receivedBy      User?           @relation(fields: [receivedById], references: [id])
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryUnits  InventoryUnit[]

  @@index([tenantId])
  @@map("goods_received_notes")
}

model InventoryUnit {
  id            String             @id @default(uuid()) @db.Uuid
  serialNumber  String             @map("serial_number") @db.VarChar(100)
  productId     String             @map("product_id") @db.Uuid
  status        UnitStatus         @default(in_stock)
  condition     UnitCondition      @default(new)
  purchasePrice Decimal?           @map("purchase_price") @db.Decimal(10, 2)
  receivedAt    DateTime           @default(now()) @map("received_at")
  grnId         String?            @map("grn_id") @db.Uuid
  notes         String?
  tenantId      String             @map("tenant_id") @db.Uuid
  grn           GoodsReceivedNote? @relation(fields: [grnId], references: [id])
  product       Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  returns       Return[]
  saleItems     SaleItem[]

  @@unique([tenantId, serialNumber])
  @@index([serialNumber])
  @@index([status])
  @@index([productId, status])
  @@index([tenantId])
  @@map("inventory_units")
}

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  phone     String   @db.VarChar(20)
  email     String?  @db.VarChar(255)
  tenantId  String   @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales     Sale[]

  @@unique([tenantId, phone])
  @@index([phone])
  @@index([tenantId])
  @@map("customers")
}

model Sale {
  id                   String             @id @default(uuid()) @db.Uuid
  invoiceNumber        String             @map("invoice_number") @db.VarChar(50)
  customerId           String?            @map("customer_id") @db.Uuid
  soldById             String?            @map("sold_by_id") @db.Uuid
  paymentMethod        PaymentMethod      @map("payment_method")
  subtotal             Decimal            @db.Decimal(12, 2)
  discountAmount       Decimal            @default(0) @map("discount_amount") @db.Decimal(10, 2)
  discountApprovedById String?            @map("discount_approved_by_id") @db.Uuid
  totalAmount          Decimal            @map("total_amount") @db.Decimal(12, 2)
  status               SaleStatus         @default(completed)
  voidReason           String?            @map("void_reason")
  voidedById           String?            @map("voided_by_id") @db.Uuid
  tenantId             String             @map("tenant_id") @db.Uuid
  createdAt            DateTime           @default(now()) @map("created_at")
  advanceAmount        Decimal            @default(0) @map("advance_amount") @db.Decimal(10, 2)
  codAmount            Decimal            @default(0) @map("cod_amount") @db.Decimal(10, 2)
  customerCity         String?            @map("customer_city") @db.VarChar(100)
  deliveryCharge       Decimal            @default(0) @map("delivery_charge") @db.Decimal(10, 2)
  isOnline             Boolean            @default(false) @map("is_online")
  shippingStatus       ShippingStatus     @default(pending) @map("shipping_status")
  trackingId           String?            @map("tracking_id") @db.VarChar(100)
  payoutReceivedAt     DateTime?          @map("payout_received_at")
  refundLossAmount     Decimal?           @map("refund_loss_amount") @db.Decimal(10, 2)
  additionalCharges    Decimal            @default(0) @map("additional_charges") @db.Decimal(10, 2)
  description          String?
  idempotencyKey       String?            @unique @map("idempotency_key") @db.Uuid
  sessionId            String?            @map("session_id") @db.Uuid
  returns              Return[]
  items                SaleItem[]
  customer             Customer?          @relation(fields: [customerId], references: [id])
  discountApprovedBy   User?              @relation("SalesDiscountApproved", fields: [discountApprovedById], references: [id])
  session              CashDrawerSession? @relation(fields: [sessionId], references: [id])
  soldBy               User?              @relation("SalesSoldBy", fields: [soldById], references: [id])
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  voidedBy             User?              @relation("SalesVoided", fields: [voidedById], references: [id])

  @@unique([tenantId, invoiceNumber])
  @@index([invoiceNumber])
  @@index([createdAt])
  @@index([soldById])
  @@index([tenantId])
  @@index([sessionId])
  @@map("sales")
}

model SaleItem {
  id              String        @id @default(uuid()) @db.Uuid
  saleId          String        @map("sale_id") @db.Uuid
  inventoryUnitId String        @map("inventory_unit_id") @db.Uuid
  sellingPrice    Decimal       @map("selling_price") @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  inventoryUnit   InventoryUnit @relation(fields: [inventoryUnitId], references: [id], onDelete: Cascade)
  sale            Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("sale_items")
}

model Return {
  id              String        @id @default(uuid()) @db.Uuid
  saleId          String        @map("sale_id") @db.Uuid
  inventoryUnitId String        @map("inventory_unit_id") @db.Uuid
  requestedById   String?       @map("requested_by_id") @db.Uuid
  reason          String
  returnType      ReturnType    @map("return_type")
  status          ReturnStatus  @default(pending)
  suspiciousFlag  Boolean       @default(false) @map("suspicious_flag")
  reviewedById    String?       @map("reviewed_by_id") @db.Uuid
  reviewNotes     String?       @map("review_notes")
  refundAmount    Decimal?      @map("refund_amount") @db.Decimal(10, 2)
  tenantId        String        @map("tenant_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at")
  resolvedAt      DateTime?     @map("resolved_at")
  inventoryUnit   InventoryUnit @relation(fields: [inventoryUnitId], references: [id], onDelete: Cascade)
  requestedBy     User?         @relation("ReturnsRequestedBy", fields: [requestedById], references: [id])
  reviewedBy      User?         @relation("ReturnsReviewedBy", fields: [reviewedById], references: [id])
  sale            Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([createdAt])
  @@index([inventoryUnitId])
  @@index([tenantId])
  @@map("returns")
}

model CashDrawerSession {
  id       String        @id @default(uuid()) @db.Uuid
  tenantId String        @map("tenant_id") @db.Uuid
  userId   String        @map("user_id") @db.Uuid
  status   SessionStatus @default(OPEN)
  openedAt DateTime      @default(now()) @map("opened_at")
  closedAt DateTime?     @map("closed_at")
  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales    Sale[]

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@map("cash_drawer_sessions")
}

model CashReconciliation {
  id             String   @id @default(uuid()) @db.Uuid
  date           DateTime @db.Date
  openingBalance Decimal  @default(0) @map("opening_balance") @db.Decimal(10, 2)
  expectedCash   Decimal  @map("expected_cash") @db.Decimal(10, 2)
  actualCash     Decimal? @map("actual_cash") @db.Decimal(10, 2)
  variance       Decimal? @db.Decimal(10, 2)
  submittedById  String?  @map("submitted_by_id") @db.Uuid
  reviewedById   String?  @map("reviewed_by_id") @db.Uuid
  notes          String?
  tenantId       String   @map("tenant_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  reviewedBy     User?    @relation("ReconciliationsReviewedBy", fields: [reviewedById], references: [id])
  submittedBy    User?    @relation("ReconciliationsSubmittedBy", fields: [submittedById], references: [id])
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([tenantId])
  @@map("cash_reconciliations")
}

model Expense {
  id          String   @id @default(uuid()) @db.Uuid
  amount      Decimal  @db.Decimal(10, 2)
  category    String   @db.VarChar(100)
  description String?
  date        DateTime @db.Date
  createdById String?  @map("created_by_id") @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   User?    @relation("ExpensesCreatedBy", fields: [createdById], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([tenantId])
  @@map("expenses")
}

model CourierPayout {
  id          String   @id @default(uuid()) @db.Uuid
  amount      Decimal  @db.Decimal(10, 2)
  courierName String?  @map("courier_name") @db.VarChar(100)
  date        DateTime @db.Date
  createdById String?  @map("created_by_id") @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  createdBy   User?    @relation("PayoutsCreatedBy", fields: [createdById], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([tenantId])
  @@map("courier_payouts")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  deviceInfo String?  @map("device_info")
  tenantId   String?  @map("tenant_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  tenant     Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([userId])
  @@index([createdAt])
  @@index([entityType, entityId])
  @@index([tenantId])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String?  @db.VarChar(100)
  message   String?
  isRead    Boolean  @default(false) @map("is_read")
  actionUrl String?  @map("action_url")
  tenantId  String?  @map("tenant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  tenant    Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([tenantId])
  @@map("notifications")
}

model Transaction {
  id        String            @id @default(uuid()) @db.Uuid
  orderId   String            @unique @map("order_id") @db.VarChar(100)
  amount    Float
  status    TransactionStatus @default(PENDING)
  tenantId  String            @map("tenant_id") @db.Uuid
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([tenantId])
  @@map("transactions")
}

enum Role {
  platform_admin
  owner
  cashier
  inventory_manager
  accountant
  technician
}

enum UnitStatus {
  in_stock
  sold
  return_pending
  returned
  damaged
  repair
  reserved
}

enum UnitCondition {
  new
  refurbished
  damaged
}

enum SaleStatus {
  completed
  voided
  partial_return
}

enum PaymentMethod {
  cash
  easypaisa
  jazzcash
  card
  bank_transfer
}

enum ReturnType {
  cash_refund
  store_credit
  exchange
}

enum ReturnStatus {
  pending
  approved
  rejected
  completed
}

enum POStatus {
  draft
  sent
  partial
  received
  cancelled
}

enum ShippingStatus {
  pending
  dispatched
  delivered
  returned
}

enum TransactionStatus {
  SUCCESS
  FAILED
  PENDING
}

enum SessionStatus {
  OPEN
  CLOSED
}
