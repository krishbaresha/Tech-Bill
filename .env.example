# ── App Config ────────────────────────────────
SHOP_NAME="My Electronics Shop"
DEFAULT_LOW_STOCK_THRESHOLD="2"                 # Alert when units drop below this
DEAD_STOCK_DAYS="60"                            # Flag units unsold longer than N days
MAX_DISCOUNT_WITHOUT_OTP="500"                  # Rs. cashier can discount below this freely
RETURN_FRAUD_WINDOW_DAYS="30"                   # Flag if same customer returns N+ times in this window
RETURN_FRAUD_COUNT_THRESHOLD="2"

# ── Rate Limiting ─────────────────────────────
RATE_LIMIT_GLOBAL="100"                         # requests/minute per IP
RATE_LIMIT_AUTH="10"                            # stricter for /auth/* routes
RATE_LIMIT_UPLOAD="5"                           # for bulk CSV import

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
ALLOWED_ORIGINS="http://localhost:5173,https://your-app.vercel.app"

# ── Bcrypt ────────────────────────────────────
BCRYPT_ROUNDS="12"
